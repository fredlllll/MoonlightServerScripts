@page
@model MoonlightDashboard.Pages.IndexModel
@{
    ViewData["Title"] = "Index";
}

@if (Model.Servers.Any()) {
    @foreach (var server in Model.Servers)
    {
        var unitInfo = Model.ServerUnitInfos[server.Id];
        <div>
        <h3>Server <a href="/servers/@server.Id">@server.Name</a></h3>
        running on port @server.Port<br />
        Status: @unitInfo.ActiveState, @unitInfo.SubState
        <br />
        @{
                var runtimeInfo = Model.ServerRuntimeInfos[server.Id];
        }
            @if(runtimeInfo != null)
            {
                <div>
                    Server Name: @runtimeInfo.Name;
                    <br />
                    Map: @runtimeInfo.Map;
                    <br />
                    Mission: @runtimeInfo.Mission;
                    <br />
                    Player Count: @runtimeInfo.Players.Count() / @runtimeInfo.MaxPlayers;
                    <br />
                    @if (runtimeInfo.Players.Any())
                    {
                        <text>Players:</text>
                        <br />
                        <ul>
                            @foreach (var player in runtimeInfo.Players)
                            {
                                <li>@player</li>
                            }
                        </ul>
                    }
                </div>
            }
            <form method="post" asp-page-handler="Start">
                <input type="submit" value="Start" />
            </form>
            <form method="post" asp-page-handler="Stop">
                <input type="submit" value="Stop" />
            </form>
            <form method="post" asp-page-handler="Restart">
                <input type="submit" value="Restart" />
            </form>
            <form method="post" asp-page-handler="Enable">
                <input type="submit" value="Enable" />
            </form>
            <form method="post" asp-page-handler="Disable">
                <input type="submit" value="Disable" />
            </form>
            <form method="post" asp-page-handler="Delete">
                <input type="submit" style="color:red;" value="Delete Server" />
            </form>
        </div>
    }

}
else
{
    <text>No servers created yet. Create one on the</text>
    <a href="/servers">servers</a>
    <text>page</text>
}
