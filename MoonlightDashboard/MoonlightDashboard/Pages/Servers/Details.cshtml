@page "{id}"
@model MoonlightDashboard.Pages.Servers.DetailsModel
@{
}
<h3>Server Info:</h3>
<table>
    <tr>
        <td>Server Name</td>
        <td>@Model.Server.Name</td>
    </tr>
    <tr>
        <td>Server Port</td>
        <td>
            <form asp-page-handler="SetPort" method="POST">
                <input type="number" name="port" value="@Model.Server.Port" placeholder="@Model.Server.Port" step="1" />
                <input type="submit" value="Set Port" />
            </form>
        </td>
    </tr>
    <tr>
        <td>Creator DLCs</td>
        <td>
            <form asp-page-handler="SetCreatorDlcs" method="POST">
                @foreach (var dlc in Model.CreatorDlcs)
                {
                    <input type="checkbox" title="@dlc.Name" name="cdlc_@dlc.ShortName" @(Model.ActiveCreatorDlcs.Contains(dlc.Id) ? "checked" : "") /> @dlc.Name<br>
                }
                <input type="submit" value="Set Creator DLCs" />
            </form>
        </td>
    </tr>
    <tr>
        <td>Status</td>
        <td>@Model.ServerUnitInfo.ActiveState, @Model.ServerUnitInfo.SubState</td>
    </tr>
    <tr>
        <td>Modset</td>
        <td>
            <form asp-page-handler="SetModset" method="POST">
                <select name="modsetId">
                    <option value="">None</option>
                    @foreach (var modset in Model.Modsets)
                    {
                        <option value="@modset.Id" selected="@(modset.Id == Model.Server.ActiveModsetId)">@modset.Name</option>
                    }
                </select>
                <input type="submit" value="Set Modset" />
            </form>
        </td>
    </tr>
</table>
<partial name="_ServerButtons" model="(Model.Server.Id, Request.Path + Request.QueryString)" />
<h3>Log:</h3>
<input type="checkbox" id="scroll-enabled" checked>Log Scroll Enabled
<br />
<textarea class="log file" id="log" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off">@Model.LastLog</textarea>
<h3>Basic Config</h3>
<form method="post" asp-page-handler="UpdateBasicConfig">
    <textarea name="content" class="file">@Model.ServerApi.GetBasicConfigFileContents()</textarea>
    <input type="submit" value="Update Basic Config" />
</form>
<form method="post" asp-page-handler="ResetBasicConfig">
    <input type="submit" value="Reset Basic Config" />
</form>
<h3>Server Config</h3>
<form method="post" asp-page-handler="UpdateServerConfig">
    <textarea name="content" class="file">@Model.ServerApi.GetServerConfigFileContents()</textarea>
    <input type="submit" value="Update Server Config" />
</form>
<form method="post" asp-page-handler="ResetServerConfig">
    <input type="submit" value="Reset Server Config" />
</form>
<h3>Server Profile</h3>
<form method="post" asp-page-handler="UpdateServerProfile">
    <textarea name="content" class="file">@Model.ServerApi.GetServerProfileFileContents()</textarea>
    <input type="submit" value="Update Server Profile" />
</form>
<form method="post" asp-page-handler="ResetServerProfile">
    <input type="submit" value="Reset Server Profile" />
</form>

<script>
    var log;
    var scrollEnabled;
    var maxLogLength = 100000;
    window.addEventListener('load',function(){
        log = document.getElementById('log');
        scrollEnabled = document.getElementById('scroll-enabled');
        frontendlibPromise.then(function(frontendlib){
            frontendlib.addChannelHandler("@Model.Server.Id",function(data){
                let newlog = log.value + data;
                if(newlog.length > maxLogLength){
                    newlog = newlog.substr(newlog.length-maxLogLength);
                }
                log.value = newlog;
                if(scrollEnabled.checked){
                    log.scrollTop = log.scrollHeight;
                }
            });
        });
    });
</script>