@page "/Servers/{id}/ServerConfig"
@model MoonlightDashboard.Pages.Servers.ServerConfigModel

<h3>Server Config</h3>
<form method="post" asp-page-handler="Update">
    <textarea name="content" class="file" style="height:50em;">@Model.ServerApi.GetServerConfigFileContents()</textarea>
    <input type="submit" value="Update Server Config" />
</form>
<form method="post" asp-page-handler="Reset">
    <input type="submit" value="Reset Server Config" />
</form>
